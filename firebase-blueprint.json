{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user data",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "balance", "role", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction Request",
      "description": "Deposit or withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountHolder": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "seen": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    },
    "GameHistory": {
      "title": "Game History",
      "description": "List of recent crash points",
      "type": "object",
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "number" }
        }
      },
      "required": ["values"]
    },
    "GameState": {
      "title": "Game State",
      "description": "Current live game status",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "startTime": { "type": "number" },
        "crashPoint": { "type": "number" },
        "currentMultiplier": { "type": "number" },
        "timer": { "type": "number" },
        "history": { "type": "array", "items": { "type": "number" } },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "startTime", "currentMultiplier"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{transId}": {
      "schema": "Transaction",
      "description": "Financial transaction requests"
    },
    "/game/history": {
      "schema": "GameHistory",
      "description": "Global game history results"
    },
    "/game/state": {
      "schema": "GameState",
      "description": "Live game machine state"
    }
  }
}
