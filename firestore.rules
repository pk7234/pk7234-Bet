rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Hardcoded admin email for convenience and fallback check
      return isSignedIn() && (
        request.auth.token.email == 'pkr4065806@gmail.com' ||
        request.auth.token.email == 'fast8585100@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    // ------------------------------------------------------------
    // COLLECTIONS
    // ------------------------------------------------------------
    
    // Game engine sync - allow write for game state updates
    match /game/{docId} {
      allow read: if true;
      allow write: if true; 
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /transactions/{transId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    // ------------------------------------------------------------
    // DEFAULT DENY
    // ------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
