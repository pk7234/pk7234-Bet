rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Hardcoded admin emails are the ONLY source of truth for admin status
      return isSignedIn() && (
        request.auth.token.email == 'pkr4065806@gmail.com' ||
        request.auth.token.email == 'fast8585100@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ------------------------------------------------------------
    // COLLECTIONS
    // ------------------------------------------------------------
    
    // Game engine sync - allow write for game state updates
    match /game/{docId} {
      allow read: if true;
      allow write: if true; 
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'user'; // Force role to user on creation
      allow update: if (isOwner(userId) && incoming().role == existing().role) || isAdmin(); // Prevent role change by owner
    }

    match /transactions/{transId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    // ------------------------------------------------------------
    // DEFAULT DENY
    // ------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
